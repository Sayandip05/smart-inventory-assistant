# ── Smart Inventory Assistant — Environment Configuration ──────────────
# Copy this file to .env and fill in real values.
# Generate SECRET_KEY with: openssl rand -hex 32

# ── Database (REQUIRED) ────────────────────────────────────────────────
# Supabase PostgreSQL: postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# ── Environment ────────────────────────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# ── API Keys ───────────────────────────────────────────────────────────
GROQ_API_KEY=
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=smart-inventory-assistant
LANGCHAIN_TRACING_V2=false

# ── Auth & Security (REQUIRED — generate with: openssl rand -hex 32) ──
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Login Lockout ──────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ── Admin Seed (first startup only) ───────────────────────────────────
ADMIN_EMAIL=admin@inventory.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=System Administrator

# ── Redis (optional — app works without it, but recommended) ──────────
# Local: redis://localhost:6379
# Upstash: rediss://default:xxx@hostname:6379
REDIS_URL=

# ── Rate Limiting ─────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=5/minute
