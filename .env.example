# ─── Smart Inventory Assistant ─── Environment Config ───
# Copy this file to .env and fill in real values

# App Settings
APP_ENV=development
APP_DEBUG=1

# Database
DATABASE_PATH=../database/smart_inventory.db

# AI / LLM (required for chatbot)
GROQ_API_KEY=your_groq_api_key_here

# Speech-to-Text (required for voice input)
SARVAM_API_KEY=your_sarvam_api_key_here

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# CORS (comma-separated allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5500,http://127.0.0.1:5500