# ─── Smart Inventory Assistant ─── Environment Config ───
# Copy this file to .env and fill in real values

# ══════════════════════════════════════════════════════════════════════════
# APPLICATION
# ══════════════════════════════════════════════════════════════════════════
ENVIRONMENT=development
PROJECT_NAME=Smart Inventory Assistant

# ══════════════════════════════════════════════════════════════════════════
# DATABASE
# ══════════════════════════════════════════════════════════════════════════
# PostgreSQL connection string (Supabase, AWS RDS, etc.)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/smart_inventory

# ══════════════════════════════════════════════════════════════════════════
# FRONTEND
# ══════════════════════════════════════════════════════════════════════════
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# ══════════════════════════════════════════════════════════════════════════
# AI / LLM (Required for chatbot)
# ══════════════════════════════════════════════════════════════════════════
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# LLM Model Configuration
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# ══════════════════════════════════════════════════════════════════════════
# LANGSMITH (Optional - AI Observability)
# ══════════════════════════════════════════════════════════════════════════
# Get your key at: https://smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=InvIQ
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ══════════════════════════════════════════════════════════════════════════
# CHROMADB (Vector Store for RAG)
# ══════════════════════════════════════════════════════════════════════════
CHROMADB_ENABLED=true
CHROMADB_PATH=data/chromadb
CHROMADB_COLLECTION=chat_memory

# ══════════════════════════════════════════════════════════════════════════
# SECURITY
# ══════════════════════════════════════════════════════════════════════════
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Login Lockout
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ══════════════════════════════════════════════════════════════════════════
# ADMIN ACCOUNTS
# ══════════════════════════════════════════════════════════════════════════
# Super Admin (platform owner)
SUPER_ADMIN_EMAIL=admin@example.com

# Default Admin (created on first startup)
ADMIN_EMAIL=admin@inventory.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_FULL_NAME=System Administrator

# ══════════════════════════════════════════════════════════════════════════
# UPSTASH REDIS (Caching & Rate Limiting)
# ══════════════════════════════════════════════════════════════════════════
# Get your credentials at: https://console.upstash.com/redis
# Create a new Redis database and copy the REST API credentials
# REST URL format: https://your-endpoint.upstash.io
# Leave empty to run without Redis (in-memory fallback)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_ENABLED=true

# ══════════════════════════════════════════════════════════════════════════
# RATE LIMITING
# ══════════════════════════════════════════════════════════════════════════
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=5/minute

# ══════════════════════════════════════════════════════════════════════════
# SMTP (Email Notifications)
# ══════════════════════════════════════════════════════════════════════════
# Set SMTP_ENABLED=true to enable email features
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@inviq.io
SMTP_FROM_NAME=InvIQ Smart Inventory

# ══════════════════════════════════════════════════════════════════════════
# EXTERNAL APIs
# ══════════════════════════════════════════════════════════════════════════
# Google OAuth (usually no need to change)
GOOGLE_OAUTH_VERIFY_URL=https://www.googleapis.com/oauth2/v3/userinfo